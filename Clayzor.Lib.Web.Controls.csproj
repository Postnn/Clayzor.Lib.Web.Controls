  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Clayzor.Lib.Entities\Clayzor.Lib.Entities.csproj" />
    <ProjectReference Include="..\Clayzor.Lib.Web.Settings\Clayzor.Lib.Web.Settings.csproj" />
  </ItemGroup>
  <Import Project="$(SolutionDir)build\StyleGuard.targets" Condition="Exists('$(SolutionDir)build\StyleGuard.targets')" />
</Project>
