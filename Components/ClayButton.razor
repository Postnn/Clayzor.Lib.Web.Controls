<MudTooltip Text="@Text" Placement="@Placement" @key="@_key">
    <MudIconButton Icon="@Icon" Size="@Size" Class="@Class"
                   OnClick="@HandleClick" Disabled="@Disabled" />
</MudTooltip>

@code {
    /// <summary>Текст тултипа.</summary>
    [Parameter] public string Text { get; set; } = "";

    /// <summary>Позиция тултипа относительно кнопки.</summary>
    [Parameter] public Placement Placement { get; set; } = Placement.Bottom;

    /// <summary>Иконка MudBlazor.</summary>
    [Parameter] public string Icon { get; set; } = "";

    /// <summary>CSS-класс кнопки.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Размер иконки.</summary>
    [Parameter] public Size Size { get; set; } = Size.Small;

    /// <summary>Блокировка кнопки.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Обработчик клика.</summary>
    [Parameter] public EventCallback OnClick { get; set; }

    private int _key;

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync();
        _key++;
    }
}
